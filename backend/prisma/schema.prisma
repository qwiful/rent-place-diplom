generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model audit_logs {
  id          Int       @id @default(autoincrement())
  user_id     Int
  action      String    @db.VarChar(100)
  entity_type String    @db.VarChar(50)
  entity_id   Int?
  old_values  Json?     @db.Json
  new_values  Json?     @db.Json
  ip_address  String?   @db.VarChar(45)
  user_agent  String?
  timestamp   DateTime? @default(now()) @db.Timestamp(6)
  users       users     @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([entity_type, entity_id], map: "idx_audit_logs_entity")
  @@index([user_id], map: "idx_audit_logs_user")
}

model business_centers {
  id              Int              @id @default(autoincrement())
  organization_id Int
  name            String           @db.VarChar(255)
  address         String
  created_at      DateTime?        @default(now()) @db.Timestamp(6)
  updated_at      DateTime?        @default(now()) @updatedAt @db.Timestamp(6)
  organizations   organizations    @relation(fields: [organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rental_objects  rental_objects[]
}

model contract_status_history {
  id                 Int       @id @default(autoincrement())
  contract_id        Int
  old_status         String?   @db.VarChar(50)
  new_status         String    @db.VarChar(50)
  changed_by_user_id Int
  change_reason      String?
  change_date        DateTime? @default(now()) @db.Timestamp(6)
  users              users     @relation(fields: [changed_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contracts          contracts @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([contract_id], map: "idx_contract_status_history_contract")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model contracts {
  id                                                              Int                       @id @default(autoincrement())
  contract_number                                                 String                    @unique @db.VarChar(100)
  rental_object_id                                                Int
  tenant_user_id                                                  Int?
  tenant_organization_id                                          Int?
  landlord_organization_id                                        Int
  start_date                                                      DateTime                  @db.Date
  end_date                                                        DateTime                  @db.Date
  monthly_rent                                                    Decimal                   @db.Decimal(12, 2)
  deposit                                                         Decimal?                  @default(0) @db.Decimal(12, 2)
  payment_day                                                     Int?
  contract_file_url                                               String?
  signed_at                                                       DateTime?                 @db.Timestamp(6)
  status                                                          contract_status_enum?     @default(draft)
  created_at                                                      DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at                                                      DateTime?                 @default(now()) @updatedAt @db.Timestamp(6)
  contract_status_history                                         contract_status_history[]
  organizations_contracts_landlord_organization_idToorganizations organizations             @relation("contracts_landlord_organization_idToorganizations", fields: [landlord_organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  rental_objects                                                  rental_objects            @relation(fields: [rental_object_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations_contracts_tenant_organization_idToorganizations   organizations?            @relation("contracts_tenant_organization_idToorganizations", fields: [tenant_organization_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                                                           users?                    @relation(fields: [tenant_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  interactions                                                    interactions[]
  service_tickets                                                 service_tickets[]

  @@index([start_date, end_date], map: "idx_contracts_dates")
  @@index([status], map: "idx_contracts_status")
}

model interactions {
  id          Int                   @id @default(autoincrement())
  contract_id Int
  type        interaction_type_enum
  content     String
  created_by  Int?
  created_at  DateTime?             @default(now()) @db.Timestamp(6)
  updated_at  DateTime?             @default(now()) @updatedAt @db.Timestamp(6)
  contracts   contracts             @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?                @relation(fields: [created_by], references: [id])

  @@index([contract_id], map: "idx_interactions_contract")
}

model organizations {
  id                                                          Int                @id @default(autoincrement())
  full_name                                                   String             @db.VarChar(255)
  short_name                                                  String?            @db.VarChar(255)
  inn                                                         String             @unique @db.VarChar(12)
  kpp                                                         String?            @db.VarChar(9)
  ogrn                                                        String?            @db.VarChar(15)
  legal_address                                               String?
  actual_address                                              String?
  phone                                                       String?            @db.VarChar(20)
  email                                                       String?            @db.VarChar(255)
  created_at                                                  DateTime?          @default(now()) @db.Timestamp(6)
  updated_at                                                  DateTime?          @default(now()) @updatedAt @db.Timestamp(6)
  users                                                       users[]
  business_centers                                            business_centers[]
  contracts_contracts_landlord_organization_idToorganizations contracts[]        @relation("contracts_landlord_organization_idToorganizations")
  contracts_contracts_tenant_organization_idToorganizations   contracts[]        @relation("contracts_tenant_organization_idToorganizations")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model rental_objects {
  id                 Int                 @id @default(autoincrement())
  business_center_id Int
  manager_id         Int?
  title              String              @db.VarChar(255)
  area               Decimal             @db.Decimal(10, 2)
  price_per_month    Decimal             @db.Decimal(12, 2)
  status             rental_status_enum? @default(available)
  created_at         DateTime?           @default(now()) @db.Timestamp(6)
  updated_at         DateTime?           @default(now()) @updatedAt @db.Timestamp(6)
  contracts          contracts[]
  business_centers   business_centers    @relation(fields: [business_center_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users              users?              @relation(fields: [manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([price_per_month], map: "idx_rental_objects_price")
  @@index([status], map: "idx_rental_objects_status")
}

model roles {
  id          Int       @id @default(autoincrement())
  name        String    @unique @db.VarChar(50)
  description String?
  updated_at  DateTime? @default(now()) @updatedAt @db.Timestamp(6)
  users       users[]
}

model service_tickets {
  id                                               Int                     @id @default(autoincrement())
  creator_id                                       Int
  contract_id                                      Int
  assigned_manager_id                              Int?
  title                                            String                  @db.VarChar(100)
  description                                      String?
  type                                             service_type_enum       @default(other)
  completion_date                                  DateTime?               @db.Timestamp(6)
  status                                           ticket_status_enum?     @default(new)
  priority                                         priority_enum?          @default(medium)
  created_at                                       DateTime?               @default(now()) @db.Timestamp(6)
  updated_at                                       DateTime?               @default(now()) @updatedAt @db.Timestamp(6)
  users_service_tickets_assigned_manager_idTousers users?                  @relation("service_tickets_assigned_manager_idTousers", fields: [assigned_manager_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  contracts                                        contracts               @relation(fields: [contract_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_service_tickets_creator_idTousers          users                   @relation("service_tickets_creator_idTousers", fields: [creator_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  ticket_status_history                            ticket_status_history[]

  @@index([priority], map: "idx_service_tickets_priority")
  @@index([status], map: "idx_service_tickets_status")
}

model ticket_status_history {
  id                 Int             @id @default(autoincrement())
  ticket_id          Int
  old_status         String?         @db.VarChar(50)
  new_status         String          @db.VarChar(50)
  changed_by_user_id Int
  change_reason      String?
  change_date        DateTime?       @default(now()) @db.Timestamp(6)
  users              users           @relation(fields: [changed_by_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  service_tickets    service_tickets @relation(fields: [ticket_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([ticket_id], map: "idx_ticket_status_history_ticket")
}

model user_profiles {
  id          Int          @id @default(autoincrement())
  user_id     Int          @unique
  first_name  String       @db.VarChar(100)
  last_name   String       @db.VarChar(100)
  middle_name String?      @db.VarChar(100)
  gender      gender_enum?
  avatar_url  String?
  created_at  DateTime?    @default(now()) @db.Timestamp(6)
  updated_at  DateTime?    @default(now()) @updatedAt @db.Timestamp(6)
  users       users        @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                                                         Int                       @id @default(autoincrement())
  phone                                                      String?                   @unique @db.VarChar(20)
  email                                                      String                    @unique @db.VarChar(255)
  password_hash                                              String                    @db.VarChar(255)
  role_id                                                    Int
  organization_id                                            Int?
  is_active                                                  Boolean?                  @default(true)
  created_at                                                 DateTime?                 @default(now()) @db.Timestamp(6)
  updated_at                                                 DateTime?                 @default(now()) @updatedAt @db.Timestamp(6)
  last_login_at                                              DateTime?                 @db.Timestamp(6)
  audit_logs                                                 audit_logs[]
  contract_status_history                                    contract_status_history[]
  contracts                                                  contracts[]
  interactions                                               interactions[]
  rental_objects                                             rental_objects[]
  service_tickets_service_tickets_assigned_manager_idTousers service_tickets[]         @relation("service_tickets_assigned_manager_idTousers")
  service_tickets_service_tickets_creator_idTousers          service_tickets[]         @relation("service_tickets_creator_idTousers")
  ticket_status_history                                      ticket_status_history[]
  user_profiles                                              user_profiles?
  roles                                                      roles                     @relation(fields: [role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  organizations                                              organizations?              @relation(fields: [organization_id], references: [id])

  @@index([role_id], map: "idx_users_role")
}

enum contract_status_enum {
  draft
  pending
  active
  terminated
  completed
}

enum gender_enum {
  male
  female
}

enum interaction_type_enum {
  phone
  email
  meeting
  note
}

enum priority_enum {
  low
  medium
  high
  critical
}

enum rental_status_enum {
  available
  occupied
  reserved
  under_renovation
}

enum service_type_enum {
  cleaning
  repair
  technical
  other
}

enum ticket_status_enum {
  new
  in_progress
  on_hold
  completed
  cancelled
}
